{
  "name": "princess-pi-packages",
  "version": "1.0.0",
  "description": "Custom global extensions for Pi Coding Agent, including DuckDuckGo search, serve with HTTPS, WTFT token auditor, and git merging.",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "bin": {
    "yada": "./bin/yada.ts",
    "dedupwcount": "./bin/yada.ts",
    "wtft": "./bin/wtft.mjs",
    "serve": "./bin/serve.mjs",
    "merge": "./bin/merge.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "build": "node build.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
